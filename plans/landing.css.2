}

/* =========================================
   HERO
   ========================================= */

.hero {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: var(--space-xl);
  align-items: end;
  padding-top: var(--space-2xl);
  padding-bottom: var(--space-xl);
}

.hero h1 {
  font-size: clamp(48px, 7vw, 88px);
