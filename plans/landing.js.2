    if (!topicButtons.length || !infoElement) return;

    var topicDescriptions = {
      TECH: "2,342 active stories across AI, startups, cybersecurity, and devices.",
      FINANCE:
        "1,780 active stories across markets, earnings, crypto, and economics.",
      GLOBAL:
