# Stage 1: Builder
FROM node:22-alpine AS builder
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile
COPY . .
RUN pnpm run build

# Stage 2: Production
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
RUN addgroup -g 1001 -S onestopnews && adduser -S onestopnews -u 1001
COPY --from=builder --chown=onestopnews:onestopnews /app/.next/standalone ./
COPY --from=builder --chown=onestopnews:onestopnews /app/.next/static ./.next/static
USER onestopnews
EXPOSE 3000
CMD ["node", "server.js"]
